DJANGO_SECRET_KEY=replace-with-a-real-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=Europe/Dublin

# Optional PostgreSQL or RDS-style database settings
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# Optional AWS cloud services
ENABLE_CLOUD_INTEGRATIONS=False
AWS_REGION=eu-west-1
AWS_S3_AUDIT_BUCKET=
USE_S3_MEDIA_STORAGE=False
AWS_S3_MEDIA_BUCKET=
AWS_S3_MEDIA_LOCATION=media
AWS_SNS_TOPIC_ARN=
AWS_SQS_QUEUE_URL=
AWS_CLOUDWATCH_NAMESPACE=PFM/Application
AWS_CONFIG_PARAMETER_NAME=
EXPENSE_ALERT_THRESHOLD=500.00
